---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import TableOfContents from '@/components/common/TableOfContents.astro';
import PostMeta from '@/components/blog/PostMeta.astro';
import ReadingProgress from '@/components/blog/ReadingProgress.astro';
import BackToTop from '@/components/blog/BackToTop.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import ReactionBar from '@/components/blog/ReactionBar.astro';
import BookmarkButton from '@/components/blog/BookmarkButton.astro';
import RelatedPosts from '@/components/blog/RelatedPosts.astro';
import NewsletterForm from '@/components/blog/NewsletterForm.astro';
import Comments from '@/components/blog/Comments.astro';
import { SITE } from '@/data/site';
import { formatDateISO } from '@/utils/date';
import { getCollection } from 'astro:content';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    publishDate: Date;
    updatedDate?: Date;
    category: string;
    tags: string[];
    series?: string;
    seriesOrder?: number;
    cover?: string;
    coverAlt?: string;
  };
  headings: { depth: number; slug: string; text: string }[];
  readingTime: number;
  slug: string;
}

const { frontmatter, headings, readingTime, slug } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: frontmatter.title,
  description: frontmatter.description,
  datePublished: formatDateISO(frontmatter.publishDate),
  dateModified: frontmatter.updatedDate ? formatDateISO(frontmatter.updatedDate) : formatDateISO(frontmatter.publishDate),
  author: {
    '@type': 'Person',
    name: SITE.author,
  },
  inLanguage: SITE.lang,
};

const breadcrumbs = [
  { label: '博客', href: '/blog' },
  { label: frontmatter.title },
];

const pageUrl = `${Astro.site || 'https://personal-blog.pages.dev'}blog/${slug}`;
const ogImageUrl = `/og/${slug}.png`;

// Get all posts for related posts
const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogImage={ogImageUrl}
  ogType="article"
  jsonLd={jsonLd}
>
  <ReadingProgress />

  <div class="container py-8">
    <div class="mb-6">
      <Breadcrumb items={breadcrumbs} />
    </div>

    <div class="flex gap-8">
      <!-- Main Content -->
      <article class="flex-1 min-w-0 max-w-[var(--content-max-width)]">
        <header class="mb-8">
          <div class="flex items-center gap-2 mb-3">
            <span class="domain-badge domain-badge-blog">博客</span>
            <span class="text-xs text-[var(--color-text-muted)] uppercase tracking-wider">{frontmatter.category}</span>
          </div>

          {frontmatter.cover && (
            <div class="mb-6 rounded-xl overflow-hidden aspect-video bg-[var(--color-bg-tertiary)]">
              <img
                src={frontmatter.cover}
                alt={frontmatter.coverAlt || frontmatter.title}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
          )}

          <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">{frontmatter.title}</h1>

          <p class="text-lg text-[var(--color-text-secondary)] mb-4">{frontmatter.description}</p>

          <div class="flex items-center justify-between flex-wrap gap-3">
            <PostMeta
              publishDate={frontmatter.publishDate}
              updatedDate={frontmatter.updatedDate}
              readingTime={readingTime}
              tags={frontmatter.tags}
            />
            <div class="flex items-center gap-2">
              <BookmarkButton slug={slug} title={frontmatter.title} />
            </div>
          </div>
        </header>

        <div class="prose prose-lg max-w-none prose-headings:scroll-mt-20 prose-a:text-[var(--color-primary)] prose-a:no-underline hover:prose-a:underline prose-code:before:content-none prose-code:after:content-none dark:prose-invert">
          <slot />
        </div>

        <!-- Post Footer: Tags + Share + Reactions -->
        <div class="mt-12 pt-6 border-t border-[var(--color-border)] space-y-6">
          <!-- Tags -->
          {frontmatter.tags.length > 0 && (
            <div class="flex flex-wrap gap-2">
              {frontmatter.tags.map((tag: string) => (
                <a
                  href={`/blog/tags/${tag}`}
                  class="px-3 py-1 text-sm rounded-full bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:bg-[var(--color-primary)]/10 hover:text-[var(--color-primary)] transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}

          <!-- Reactions -->
          <ReactionBar slug={slug} />

          <!-- Share -->
          <ShareButtons title={frontmatter.title} url={pageUrl} description={frontmatter.description} />
        </div>

        <!-- Related Posts -->
        <RelatedPosts
          currentSlug={slug}
          currentTags={frontmatter.tags}
          currentCategory={frontmatter.category}
          allPosts={allPosts}
        />

        <!-- Comments -->
        <Comments path={`/blog/${slug}`} />

        <!-- Newsletter CTA -->
        <div class="mt-12">
          <NewsletterForm />
        </div>
      </article>

      <!-- Table of Contents (Desktop) -->
      <aside class="hidden xl:block w-[var(--toc-width)] shrink-0">
        <TableOfContents headings={headings} />
      </aside>
    </div>
  </div>

  <BackToTop />
</BaseLayout>
