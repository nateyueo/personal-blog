---
import BaseLayout from './BaseLayout.astro';
import DocSidebar from '@/components/docs/DocSidebar.astro';
import DocPagination from '@/components/docs/DocPagination.astro';
import Breadcrumb from '@/components/common/Breadcrumb.astro';
import TableOfContents from '@/components/common/TableOfContents.astro';
import { SITE, DOCS_EDIT_URL } from '@/data/site';
import { formatDateISO } from '@/utils/date';
import type { SidebarSection } from '@/utils/docs-sidebar';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    section: string;
    tableOfContents?: boolean;
    editUrl?: boolean;
    status?: string;
    badge?: { text: string; variant: string };
  };
  headings: { depth: number; slug: string; text: string }[];
  currentSlug: string;
  sidebarSections: SidebarSection[];
  prev?: { title: string; slug: string } | null;
  next?: { title: string; slug: string } | null;
}

const { frontmatter, headings, currentSlug, sidebarSections, prev, next } = Astro.props;

const SECTION_LABELS: Record<string, string> = {
  'getting-started': '快速入门',
  'prd-methodology': 'PRD 方法论',
  'templates': '模板库',
  'best-practices': '最佳实践',
  'api-reference': 'API 参考',
};

const sectionLabel = SECTION_LABELS[frontmatter.section] || frontmatter.section;

const breadcrumbs = [
  { label: '手册', href: '/docs/getting-started/introduction' },
  { label: sectionLabel },
  { label: frontmatter.title },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: frontmatter.title,
  description: frontmatter.description,
  author: { '@type': 'Person', name: SITE.author },
  inLanguage: SITE.lang,
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description || `${frontmatter.title} - PRD 手册`}
  jsonLd={jsonLd}
>
  <div class="container py-8">
    <div class="flex gap-8">
      <!-- Left Sidebar -->
      <DocSidebar sections={sidebarSections} currentSlug={currentSlug} />

      <!-- Main Content -->
      <article class="flex-1 min-w-0 max-w-[var(--content-max-width)]">
        <div class="mb-6">
          <Breadcrumb items={breadcrumbs} />
        </div>

        <header class="mb-8">
          <div class="flex items-center gap-2 mb-3">
            <span class="domain-badge domain-badge-docs">手册</span>
            {frontmatter.badge && (
              <span class:list={[
                'px-2 py-0.5 text-xs font-semibold rounded',
                frontmatter.badge.variant === 'success' && 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
                frontmatter.badge.variant === 'info' && 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
                frontmatter.badge.variant === 'warning' && 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',
                frontmatter.badge.variant === 'danger' && 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
              ]}>
                {frontmatter.badge.text}
              </span>
            )}
            {frontmatter.status === 'deprecated' && (
              <span class="px-2 py-0.5 text-xs font-semibold rounded bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400">已废弃</span>
            )}
          </div>

          <h1 class="text-3xl font-bold leading-tight">{frontmatter.title}</h1>
          {frontmatter.description && (
            <p class="mt-2 text-lg text-[var(--color-text-secondary)]">{frontmatter.description}</p>
          )}
        </header>

        <div class="prose prose-lg max-w-none prose-headings:scroll-mt-20 prose-a:text-[var(--color-primary)] prose-a:no-underline hover:prose-a:underline prose-code:before:content-none prose-code:after:content-none dark:prose-invert">
          <slot />
        </div>

        <!-- Edit link -->
        {frontmatter.editUrl !== false && (
          <div class="mt-8 pt-4 border-t border-[var(--color-border)]">
            <a
              href={`${DOCS_EDIT_URL}${currentSlug}.mdx`}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              在 GitHub 上编辑此页
            </a>
          </div>
        )}

        <DocPagination prev={prev} next={next} />
      </article>

      <!-- Right TOC -->
      {frontmatter.tableOfContents !== false && (
        <aside class="hidden xl:block w-[var(--toc-width)] shrink-0">
          <TableOfContents headings={headings} />
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
