---
import type { SidebarSection } from '@/utils/docs-sidebar';

interface Props {
  sections: SidebarSection[];
  currentSlug: string;
}

const { sections, currentSlug } = Astro.props;
---

<!-- Mobile sidebar toggle -->
<button
  id="docs-sidebar-toggle"
  class="lg:hidden fixed bottom-6 right-6 z-40 flex items-center gap-2 px-4 py-2.5 rounded-full bg-[var(--color-primary)] text-white shadow-lg hover:shadow-xl transition-all"
  aria-label="打开目录"
>
  <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h7" />
  </svg>
  <span class="text-sm font-medium">目录</span>
</button>

<!-- Sidebar overlay (mobile) -->
<div id="docs-sidebar-overlay" class="hidden lg:hidden fixed inset-0 z-40 bg-black/50 backdrop-blur-sm"></div>

<!-- Sidebar -->
<aside
  id="docs-sidebar"
  class="fixed lg:sticky top-0 lg:top-20 left-0 z-50 lg:z-0 h-screen lg:h-[calc(100vh-5rem)] w-[var(--sidebar-width)] -translate-x-full lg:translate-x-0 bg-[var(--color-bg)] lg:bg-transparent border-r lg:border-r-0 border-[var(--color-border)] overflow-y-auto transition-transform duration-300"
>
  <!-- Mobile close button -->
  <div class="lg:hidden flex items-center justify-between p-4 border-b border-[var(--color-border)]">
    <h3 class="font-semibold text-sm">手册目录</h3>
    <button id="docs-sidebar-close" class="p-1 rounded hover:bg-[var(--color-bg-tertiary)]" aria-label="关闭目录">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <nav class="p-4 lg:pl-0" aria-label="手册导航">
    {sections.map((section) => (
      <div class="mb-6">
        <h4 class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-2 px-2">
          {section.label}
        </h4>
        <ul class="space-y-0.5">
          {section.items.map((item) => {
            const isActive = currentSlug === item.slug;
            return (
              <li>
                <a
                  href={`/docs/${item.slug}`}
                  class:list={[
                    'flex items-center gap-2 px-2 py-1.5 rounded-lg text-sm transition-colors',
                    isActive
                      ? 'bg-[var(--color-primary)]/10 text-[var(--color-primary)] font-medium'
                      : 'text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-bg-tertiary)]',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  <span class="truncate">{item.title}</span>
                  {item.badge && (
                    <span class:list={[
                      'shrink-0 px-1.5 py-0.5 text-[10px] font-semibold rounded',
                      item.badge.variant === 'success' && 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400',
                      item.badge.variant === 'info' && 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400',
                      item.badge.variant === 'warning' && 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400',
                      item.badge.variant === 'danger' && 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400',
                    ]}>
                      {item.badge.text}
                    </span>
                  )}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<script>
  const toggle = document.getElementById('docs-sidebar-toggle');
  const close = document.getElementById('docs-sidebar-close');
  const overlay = document.getElementById('docs-sidebar-overlay');
  const sidebar = document.getElementById('docs-sidebar');

  function openSidebar() {
    sidebar?.classList.remove('-translate-x-full');
    sidebar?.classList.add('translate-x-0');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebar?.classList.add('-translate-x-full');
    sidebar?.classList.remove('translate-x-0');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openSidebar);
  close?.addEventListener('click', closeSidebar);
  overlay?.addEventListener('click', closeSidebar);
</script>
