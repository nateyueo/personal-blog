---
import { formatDate } from '@/utils/date';
import { formatReadingTime } from '@/utils/reading-time';

interface Props {
  publishDate: Date;
  updatedDate?: Date;
  readingTime: number;
  tags?: string[];
}

const { publishDate, updatedDate, readingTime } = Astro.props;
---

<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-[var(--color-text-muted)]">
  <time datetime={publishDate.toISOString()}>
    {formatDate(publishDate)}
  </time>

  {updatedDate && (
    <span class="flex items-center gap-1">
      <span>更新于</span>
      <time datetime={updatedDate.toISOString()}>{formatDate(updatedDate)}</time>
    </span>
  )}

  <span>·</span>
  <span>{formatReadingTime(readingTime)}</span>
</div>
