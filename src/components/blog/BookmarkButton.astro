---
interface Props {
  slug: string;
  title: string;
}

const { slug, title } = Astro.props;
---

<button
  class="bookmark-btn inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] hover:border-[var(--color-primary)]/40 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-all cursor-pointer"
  data-slug={slug}
  data-title={title}
  aria-label="收藏文章"
>
  <svg class="bookmark-icon w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" />
  </svg>
  <span class="bookmark-text text-xs">收藏</span>
</button>

<script>
  document.querySelectorAll('.bookmark-btn').forEach((btn) => {
    const slug = (btn as HTMLElement).dataset.slug || '';
    const title = (btn as HTMLElement).dataset.title || '';
    const icon = btn.querySelector('.bookmark-icon') as SVGElement;
    const text = btn.querySelector('.bookmark-text') as HTMLElement;

    const STORAGE_KEY = 'bookmarks';

    const getBookmarks = (): { slug: string; title: string; date: string }[] => {
      try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); }
      catch { return []; }
    };

    const isBookmarked = () => getBookmarks().some((b) => b.slug === slug);

    const render = () => {
      if (isBookmarked()) {
        icon.setAttribute('fill', 'currentColor');
        text.textContent = '已收藏';
        btn.classList.add('text-[var(--color-primary)]', 'border-[var(--color-primary)]');
      } else {
        icon.setAttribute('fill', 'none');
        text.textContent = '收藏';
        btn.classList.remove('text-[var(--color-primary)]', 'border-[var(--color-primary)]');
      }
    };

    btn.addEventListener('click', () => {
      const bookmarks = getBookmarks();
      if (isBookmarked()) {
        const idx = bookmarks.findIndex((b) => b.slug === slug);
        if (idx > -1) bookmarks.splice(idx, 1);
      } else {
        bookmarks.unshift({ slug, title, date: new Date().toISOString() });
      }
      localStorage.setItem(STORAGE_KEY, JSON.stringify(bookmarks));
      render();
    });

    render();
  });

  // Track reading history
  (() => {
    const slug = window.location.pathname;
    const title = document.title;
    const HISTORY_KEY = 'reading-history';
    const MAX_HISTORY = 50;

    try {
      const history: { slug: string; title: string; date: string }[] = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]');
      const filtered = history.filter((h) => h.slug !== slug);
      filtered.unshift({ slug, title, date: new Date().toISOString() });
      localStorage.setItem(HISTORY_KEY, JSON.stringify(filtered.slice(0, MAX_HISTORY)));
    } catch { /* ignore */ }
  })();
</script>
