---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
  type?: 'info' | 'tip' | 'warning' | 'danger';
  title?: string;
}

const { type = 'info', title, ...rest } = Astro.props;

const styles: Record<string, { bg: string; border: string; icon: string; titleColor: string }> = {
  info: {
    bg: 'bg-blue-50 dark:bg-blue-950/30',
    border: 'border-blue-400',
    icon: 'ℹ️',
    titleColor: 'text-blue-700 dark:text-blue-300',
  },
  tip: {
    bg: 'bg-green-50 dark:bg-green-950/30',
    border: 'border-green-400',
    icon: '💡',
    titleColor: 'text-green-700 dark:text-green-300',
  },
  warning: {
    bg: 'bg-amber-50 dark:bg-amber-950/30',
    border: 'border-amber-400',
    icon: '⚠️',
    titleColor: 'text-amber-700 dark:text-amber-300',
  },
  danger: {
    bg: 'bg-red-50 dark:bg-red-950/30',
    border: 'border-red-400',
    icon: '🚨',
    titleColor: 'text-red-700 dark:text-red-300',
  },
};

const s = styles[type];
---

<div class={`my-6 rounded-lg border-l-4 ${s.border} ${s.bg} p-4`} {...rest}>
  {title && (
    <p class={`font-semibold ${s.titleColor} mb-1 flex items-center gap-2`}>
      <span>{s.icon}</span>
      {title}
    </p>
  )}
  <div class="text-sm leading-relaxed [&>p]:mb-2 [&>p:last-child]:mb-0">
    <slot />
  </div>
</div>
