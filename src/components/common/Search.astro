---
---

<!-- Search Modal -->
<div
  id="search-modal"
  class="hidden fixed inset-0 z-[100] flex items-start justify-center pt-[15vh]"
  role="dialog"
  aria-modal="true"
  aria-label="站内搜索"
>
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <!-- Dialog -->
  <div class="relative w-full max-w-xl mx-4 bg-[var(--color-bg)] rounded-2xl shadow-2xl border border-[var(--color-border)] overflow-hidden">
    <!-- Search Input -->
    <div class="flex items-center gap-3 px-4 py-3 border-b border-[var(--color-border)]">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-[var(--color-text-muted)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input
        id="search-input"
        type="text"
        placeholder="搜索文章、手册..."
        class="flex-1 bg-transparent text-[var(--color-text)] placeholder:text-[var(--color-text-muted)] outline-none text-base"
        autocomplete="off"
      />
      <kbd class="hidden sm:inline px-2 py-0.5 text-xs bg-[var(--color-bg-tertiary)] rounded border border-[var(--color-border)] text-[var(--color-text-muted)]">
        Esc
      </kbd>
    </div>

    <!-- Results -->
    <div id="search-results" class="max-h-[50vh] overflow-y-auto p-2">
      <div id="search-empty" class="py-8 text-center text-sm text-[var(--color-text-muted)]">
        输入关键词开始搜索
      </div>
      <div id="search-list" class="hidden space-y-1"></div>
      <div id="search-no-results" class="hidden py-8 text-center text-sm text-[var(--color-text-muted)]">
        未找到匹配结果
      </div>
    </div>

    <!-- Footer -->
    <div class="px-4 py-2 border-t border-[var(--color-border)] flex items-center justify-between text-xs text-[var(--color-text-muted)]">
      <div class="flex gap-3">
        <span><kbd class="px-1 py-0.5 bg-[var(--color-bg-tertiary)] rounded">↑↓</kbd> 导航</span>
        <span><kbd class="px-1 py-0.5 bg-[var(--color-bg-tertiary)] rounded">↵</kbd> 打开</span>
      </div>
      <span>Powered by Fuse.js</span>
    </div>
  </div>
</div>

<script>
  import Fuse, { type FuseResult } from 'fuse.js';

  interface SearchItem {
    type: 'blog' | 'docs';
    title: string;
    description: string;
    tags: string[];
    category: string;
    url: string;
  }

  type ItemType = SearchItem['type'];

  let fuse: Fuse<SearchItem> | null = null;
  let searchData: SearchItem[] = [];
  let selectedIndex = -1;

  const modal = document.getElementById('search-modal')!;
  const backdrop = document.getElementById('search-backdrop')!;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const listEl = document.getElementById('search-list')!;
  const emptyEl = document.getElementById('search-empty')!;
  const noResultsEl = document.getElementById('search-no-results')!;
  const trigger = document.getElementById('search-trigger');

  async function loadSearchIndex() {
    if (fuse) return;
    const res = await fetch('/search.json');
    searchData = await res.json();
    fuse = new Fuse(searchData, {
      keys: [
        { name: 'title', weight: 3 },
        { name: 'description', weight: 2 },
        { name: 'tags', weight: 1.5 },
        { name: 'category', weight: 1 },
      ],
      threshold: 0.4,
      minMatchCharLength: 2,
      includeMatches: true,
    });
  }

  function openSearch() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    input.focus();
    loadSearchIndex();
  }

  function closeSearch() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    selectedIndex = -1;
    showEmpty();
  }

  function showEmpty() {
    emptyEl.classList.remove('hidden');
    listEl.classList.add('hidden');
    noResultsEl.classList.add('hidden');
  }

  function renderResults(results: FuseResult<SearchItem>[]) {
    if (results.length === 0) {
      emptyEl.classList.add('hidden');
      listEl.classList.add('hidden');
      noResultsEl.classList.remove('hidden');
      return;
    }

    emptyEl.classList.add('hidden');
    noResultsEl.classList.add('hidden');
    listEl.classList.remove('hidden');

    const typeLabel: Record<ItemType, string> = { blog: '博客', docs: '手册' };
    const typeColor: Record<ItemType, string> = {
      blog: 'bg-[var(--color-domain-blog)]/10 text-[var(--color-domain-blog)]',
      docs: 'bg-[var(--color-domain-docs)]/10 text-[var(--color-domain-docs)]',
    };

    listEl.innerHTML = results
      .slice(0, 10)
      .map(
        (r, i) => `
        <a
          href="${r.item.url}"
          class="search-result flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-[var(--color-bg-tertiary)] transition-colors ${i === selectedIndex ? 'bg-[var(--color-bg-tertiary)]' : ''}"
          data-index="${i}"
        >
          <span class="shrink-0 px-1.5 py-0.5 text-[10px] font-semibold rounded ${typeColor[r.item.type]}">${typeLabel[r.item.type]}</span>
          <div class="flex-1 min-w-0">
            <div class="text-sm font-medium truncate">${r.item.title}</div>
            <div class="text-xs text-[var(--color-text-muted)] truncate">${r.item.description}</div>
          </div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-[var(--color-text-muted)] shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      `
      )
      .join('');
  }

  // Event listeners
  trigger?.addEventListener('click', openSearch);
  backdrop.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      modal.classList.contains('hidden') ? openSearch() : closeSearch();
    }
    if (e.key === 'Escape') closeSearch();
  });

  let debounceTimer: ReturnType<typeof setTimeout>;
  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      const query = input.value.trim();
      if (!query || !fuse) {
        showEmpty();
        return;
      }
      selectedIndex = -1;
      const results = fuse.search(query);
      renderResults(results);
    }, 200);
  });

  input.addEventListener('keydown', (e) => {
    const items = listEl.querySelectorAll<HTMLAnchorElement>('.search-result');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIndex = Math.min(selectedIndex + 1, items.length - 1);
      items.forEach((el, i) => el.classList.toggle('bg-[var(--color-bg-tertiary)]', i === selectedIndex));
      items[selectedIndex]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIndex = Math.max(selectedIndex - 1, 0);
      items.forEach((el, i) => el.classList.toggle('bg-[var(--color-bg-tertiary)]', i === selectedIndex));
      items[selectedIndex]?.scrollIntoView({ block: 'nearest' });
    } else if (e.key === 'Enter' && selectedIndex >= 0) {
      e.preventDefault();
      items[selectedIndex]?.click();
    }
  });
</script>
