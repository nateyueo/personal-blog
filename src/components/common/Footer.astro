---
import { SITE, SOCIAL_LINKS } from '@/data/site';
const year = new Date().getFullYear();
---

<footer class="border-t border-[var(--color-border)] bg-[var(--color-bg-secondary)] mt-auto">
  <div class="container py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- About -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-3">关于本站</h3>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          以「PRD 方法论沉淀」为主线的个人站点，涵盖博客观点输出与手册知识体系。
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-3">快速链接</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/blog" class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">博客</a></li>
          <li><a href="/docs/getting-started/introduction" class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">手册</a></li>
          <li><a href="/about" class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">关于</a></li>
          <li><a href="/rss.xml" class="text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] transition-colors">RSS 订阅</a></li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-semibold text-sm uppercase tracking-wider text-[var(--color-text-muted)] mb-3">社交链接</h3>
        <div class="flex gap-3">
          {SOCIAL_LINKS.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center justify-center w-9 h-9 rounded-lg bg-[var(--color-bg-tertiary)] text-[var(--color-text-secondary)] hover:text-[var(--color-primary)] hover:bg-[var(--color-primary)]/10 transition-colors"
              aria-label={link.label}
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-8 pt-6 border-t border-[var(--color-border)] flex flex-col sm:flex-row justify-between items-center gap-2 text-xs text-[var(--color-text-muted)]">
      <p>&copy; {year} {SITE.author}. All rights reserved.</p>
      <p>使用 <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-[var(--color-primary)]">Astro</a> 构建</p>
    </div>
  </div>
</footer>
