---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/blog/PostCard.astro';
import NewsletterForm from '@/components/blog/NewsletterForm.astro';
import { getCollection, render } from 'astro:content';
import { SITE } from '@/data/site';
import { formatDate } from '@/utils/date';

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const featuredPosts = allPosts
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 5);

const allDocs = await getCollection('docs', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

// Recent thoughts
const allThoughts = await getCollection('thoughts', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});
const recentThoughts = allThoughts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);

const moodEmoji: Record<string, string> = {
  happy: '😊', thinking: '🤔', excited: '🎉', neutral: '📝', sad: '😢',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE.title,
  description: SITE.description,
  url: Astro.site?.href,
  author: { '@type': 'Person', name: SITE.author },
  inLanguage: SITE.lang,
};
---

<BaseLayout jsonLd={jsonLd}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden border-b border-[var(--color-border)]">
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)]/5 via-transparent to-[var(--color-accent)]/5"></div>
    <div class="container relative py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-4">
          <span class="text-[var(--color-primary)]">PRD 手册</span> & 个人博客
        </h1>
        <p class="text-lg md:text-xl text-[var(--color-text-secondary)] mb-8 leading-relaxed">
          以「产品需求文档方法论沉淀」为主线的个人站点，涵盖博客观点输出、手册知识体系与实用工具箱。
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="/docs/getting-started/introduction"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[var(--color-primary)] text-white font-medium hover:bg-[var(--color-primary-dark)] transition-colors shadow-md hover:shadow-lg"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            阅读手册
          </a>
          <a
            href="/blog"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-[var(--color-border)] font-medium hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
            浏览博客
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Continue Reading (client-side from localStorage) -->
  <section class="container pt-8" id="continue-reading-section" style="display:none;">
    <div class="p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-secondary)]">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-base">📖</span>
        <h3 class="font-semibold text-sm">继续阅读</h3>
      </div>
      <div id="continue-reading-list" class="flex gap-3 overflow-x-auto pb-1"></div>
    </div>
  </section>

  <script>
    try {
      const history: { slug: string; title: string; date: string }[] = JSON.parse(localStorage.getItem('reading-history') || '[]');
      const section = document.getElementById('continue-reading-section');
      const list = document.getElementById('continue-reading-list');
      if (history.length > 0 && section && list) {
        section.style.display = 'block';
        history.slice(0, 5).forEach((h) => {
          const a = document.createElement('a');
          a.href = h.slug;
          a.className = 'flex-shrink-0 px-4 py-2 rounded-lg bg-[var(--color-bg)] border border-[var(--color-border)] hover:border-[var(--color-primary)]/40 text-sm transition-colors';
          a.textContent = h.title.replace(/ \|.*$/, '');
          list.appendChild(a);
        });
      }
    } catch { /* ignore */ }
  </script>

  <!-- Content Domains -->
  <section class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <a href="/blog" class="group p-6 rounded-2xl border border-[var(--color-border)] hover:border-[var(--color-domain-blog)]/40 hover:shadow-lg transition-all domain-bar-blog">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-[var(--color-domain-blog)]/10 text-[var(--color-domain-blog)]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg group-hover:text-[var(--color-domain-blog)] transition-colors">博客</h3>
        </div>
        <p class="text-sm text-[var(--color-text-secondary)]">技术观点、案例复盘与产品思考，{allPosts.length} 篇文章</p>
      </a>

      <a href="/docs/getting-started/introduction" class="group p-6 rounded-2xl border border-[var(--color-border)] hover:border-[var(--color-domain-docs)]/40 hover:shadow-lg transition-all domain-bar-docs">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-[var(--color-domain-docs)]/10 text-[var(--color-domain-docs)]">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg group-hover:text-[var(--color-domain-docs)] transition-colors">PRD 手册</h3>
        </div>
        <p class="text-sm text-[var(--color-text-secondary)]">PRD 方法论、模板、清单与最佳实践，{allDocs.length} 篇文档</p>
      </a>

      <a href="/thoughts" class="group p-6 rounded-2xl border border-[var(--color-border)] hover:border-purple-400/40 hover:shadow-lg transition-all" style="border-left: 4px solid #A855F7;">
        <div class="flex items-center gap-3 mb-3">
          <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-purple-500/10 text-purple-500">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
            </svg>
          </div>
          <h3 class="font-semibold text-lg group-hover:text-purple-500 transition-colors">随想</h3>
        </div>
        <p class="text-sm text-[var(--color-text-secondary)]">碎片化的想法与灵感记录，{allThoughts.length} 条随想</p>
      </a>
    </div>
  </section>

  <!-- Featured Posts -->
  {featuredPosts.length > 0 && (
    <section class="container py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">精选文章</h2>
        <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">查看全部 →</a>
      </div>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {featuredPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.id}
            featured={post.data.featured}
            cover={post.data.cover}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Recent Thoughts -->
  {recentThoughts.length > 0 && (
    <section class="container py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">💭 最近随想</h2>
        <a href="/thoughts" class="text-sm text-[var(--color-primary)] hover:underline">查看全部 →</a>
      </div>
      <div class="space-y-3">
        {recentThoughts.map((thought) => (
          <div class="p-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)]">
            <div class="flex items-start gap-3">
              <span class="text-xl flex-shrink-0">{moodEmoji[thought.data.mood] || '📝'}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm leading-relaxed">{thought.body?.slice(0, 200)}</p>
                <div class="flex items-center gap-3 mt-2 text-xs text-[var(--color-text-muted)]">
                  <time datetime={thought.data.publishDate.toISOString()}>{formatDate(thought.data.publishDate)}</time>
                  <div class="flex gap-1">
                    {thought.data.tags.map((tag: string) => (
                      <span class="px-1.5 py-0.5 rounded bg-[var(--color-bg-tertiary)]">#{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="container py-12">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold">最近更新</h2>
        <a href="/blog" class="text-sm text-[var(--color-primary)] hover:underline">查看全部 →</a>
      </div>
      <div class="grid gap-4">
        {recentPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            category={post.data.category}
            tags={post.data.tags}
            slug={post.id}
            cover={post.data.cover}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter -->
  <section class="container py-12">
    <div class="max-w-xl mx-auto">
      <NewsletterForm />
    </div>
  </section>
</BaseLayout>
